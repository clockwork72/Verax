# Copy this file to `hpc/scraper/local.env` and fill in your real values.
# `local.env` is gitignored and sourced automatically by the HPC helper scripts.

: "${SCRAPER_SSH_HOST:=your-user@login.your-hpc.example}"
: "${SCRAPER_CLUSTER_FQDN:=login.your-hpc.example}"
: "${SCRAPER_REMOTE_ROOT:=/path/to/your/hpc/scraper}"
export SCRAPER_SSH_HOST SCRAPER_CLUSTER_FQDN SCRAPER_REMOTE_ROOT

# Optional overrides
# : "${SCRAPER_REPO_ROOT:=${SCRAPER_REMOTE_ROOT}/repo}"
# : "${SCRAPER_RUNTIME_ROOT:=${SCRAPER_REMOTE_ROOT}/runtime}"
# : "${SCRAPER_OUTPUTS_ROOT:=${SCRAPER_REPO_ROOT}/outputs}"
# : "${SCRAPER_SBATCH_EXTRA_ARGS:=--account=your-slurm-account --output=/path/to/logs/orchestrator_%j.out --error=/path/to/logs/orchestrator_%j.err}"
# export SCRAPER_REPO_ROOT SCRAPER_RUNTIME_ROOT SCRAPER_OUTPUTS_ROOT SCRAPER_SBATCH_EXTRA_ARGS
